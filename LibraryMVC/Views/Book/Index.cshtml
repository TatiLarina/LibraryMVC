@model IEnumerable<LibraryMVC.Models.Book>
@{
    ViewData["Title"] = "Список книг";
}

<h1>📚 Домашняя библиотека</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">➕ Добавить книгу</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Автор</th>
            <th>Год</th>
            <th>Жанр</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.Year</td>
                <td>@item.Genre</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.BookID" class="btn btn-sm btn-info">👁️</a>
                    <a asp-action="Edit" asp-route-id="@item.BookID" class="btn btn-sm btn-warning">✏️</a>
                    <a asp-action="Delete" asp-route-id="@item.BookID" class="btn btn-sm btn-danger">🗑️</a>
                </td>
            </tr>
        }
    </tbody>
</table>
